{
  "name": "yeshiva-tkoa",
  "version": "0.0.0",
  "private": true,
  "description": "Монорепо сайта Ешивы «ХаБаД Ткоа» — web (Next), admin (Next+MUI), api (Express+MySQL)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:fast": "docker compose -f docker-compose.fast.yml up --build --watch",
    "dev:docker:fast:reset": "docker compose -f docker-compose.fast.yml stop && docker volume rm yeshiva-fast_app_workspace",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
