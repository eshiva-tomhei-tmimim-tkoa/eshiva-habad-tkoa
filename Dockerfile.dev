# Общий dev-образ монорепо (api/web/admin). Команда задаётся в compose.
# Цель: гонять dev-серверы в Linux-контейнерах, чтобы артефакты сборки
# (.next, node_modules, dist) жили в томах на ext4, а не на синхронизируемом
# OneDrive (там Next падает на readlink EINVAL). Исходники — bind-mount.
FROM node:22-alpine
RUN apk add --no-cache libc6-compat
RUN corepack enable
WORKDIR /app

# Установка зависимостей всего workspace (попадёт в node_modules-тома).
# Кэш-маунт стора pnpm — переживает повторные сборки и снижает нагрузку на сеть.
COPY . .
RUN pnpm config set store-dir /pnpm-store
RUN --mount=type=cache,target=/pnpm-store pnpm install --frozen-lockfile
# Сгенерировать Prisma-клиент и собрать общий пакет типов.
RUN pnpm --filter @yeshiva/api exec prisma generate
RUN pnpm --filter @yeshiva/types build

CMD ["pnpm", "-r", "--parallel", "dev"]
