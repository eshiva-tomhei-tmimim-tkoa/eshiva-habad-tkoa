# --- БД (MySQL) ---
# Хост-порт 3307 (docker-compose маппит 3307→3306), чтобы не конфликтовать
# с локально установленным MySQL на 3306.
DATABASE_URL="mysql://yeshiva:yeshiva@localhost:3307/yeshiva_tkoa"
MYSQL_ROOT_PASSWORD="root"
MYSQL_DATABASE="yeshiva_tkoa"
MYSQL_USER="yeshiva"
MYSQL_PASSWORD="yeshiva"

# --- API (Express) ---
API_PORT=4000
JWT_SECRET="change-me-in-production"
UPLOAD_DIR="./uploads"
# CORS — домены фронтов, через запятую
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# --- Фронты (Next) ---
# Публичный сайт
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# --- Платежи: Israel Toremet / IsraelGives (этап 6) ---
# Полный URL кастомной донат-формы (узнать в кабинете IsraelGives):
#   https://secureddonation.com/en/pay/<slug>
TOREMET_PAY_URL=""
# Альтернатива — gov-id амуты для некастомной формы (если PAY_URL не задан):
# TOREMET_AMUTA_GOV_ID=""
# Публичный URL сайта для successurl возврата донора:
WEB_PUBLIC_URL="http://localhost:3000"
# (опц.) переопределение id валют IsraelGives, JSON. USD=2 подтверждён; ILS уточнить.
# TOREMET_CURRENCY_IDS='{"ILS":1,"USD":2}'
